<div class="container py-4">

  <!-- 🔥 HEADER -->
  <div class="mb-4">
    <h3 class="fw-semibold mb-1">Create Task</h3>
    <p class="text-muted small mb-0">
      Add a new task and assign it to a team member
    </p>
  </div>

  <!-- 🔥 FORM CARD -->
  <div class="card shadow-sm border-0 p-4" style="max-width:700px;">

    <!-- ERROR -->
    <% if (typeof error !== 'undefined') { %>
      <div class="alert alert-danger">
        <%= error %>
      </div>
    <% } %>

    <form method="POST" action="/tasks/create">

      <!-- TITLE -->
      <div class="mb-3">
        <label class="form-label small fw-semibold">Task Title</label>
        <input 
          name="title" 
          class="form-control form-control-lg" 
          placeholder="e.g. Fix login bug"
          required 
        />
      </div>

      <!-- DESCRIPTION -->
      <div class="mb-3">
        <label class="form-label small fw-semibold">Description</label>
        <textarea 
          name="description" 
          class="form-control" 
          rows="3"
          placeholder="Add task details"
        ></textarea>
      </div>

      <!-- PRIORITY + DATE -->
      <div class="row mb-3">

        <div class="col-md-6">
          <label class="form-label small fw-semibold">Priority</label>
          <select name="priority" class="form-select">
            <option value="low">Low</option>
            <option value="medium" selected>Medium</option>
            <option value="high">High</option>
          </select>
        </div>

        <div class="col-md-6">
          <label class="form-label small fw-semibold">Due Date</label>
          <input type="date" name="due_date" class="form-control" />
        </div>

      </div>

      <!-- PROJECT -->
      <div class="mb-3">
        <label class="form-label small fw-semibold">Project</label>
        <select name="project_id" class="form-select">
          <% projects.forEach(p => { %>
            <option value="<%= p.id %>"><%= p.name %></option>
          <% }) %>
        </select>
      </div>

      <!-- ASSIGNEE -->
      <div class="mb-4">
        <label class="form-label small fw-semibold">Assign To</label>
        <select name="assigned_to" class="form-select">
          <% users.forEach(u => { %>
            <option value="<%= u.id %>"><%= u.name %></option>
          <% }) %>
        </select>
      </div>

      <!-- ACTIONS -->
      <div class="d-flex justify-content-between">

        <a href="/tasks" class="btn btn-outline-secondary">
          Cancel
        </a>

        <button class="btn btn-success px-4">
          Create Task
        </button>

      </div>

    </form>

  </div>

</div>
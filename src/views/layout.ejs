<!DOCTYPE html>
<html>
<head>
  <title>Task Manager</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container-fluid">
    <a class="navbar-brand" href="/dashboard">TaskManager</a>

    <div class="collapse navbar-collapse">
    <ul class="navbar-nav me-auto">

    <% if (user && user.role === 'admin') { %>
        <li class="nav-item">
        <a class="nav-link" href="/projects">Projects</a>
        </li>
        <li class="nav-item">
        <a class="nav-link" href="/tasks">All Tasks</a>
        </li>
        <li class="nav-item">
        <a class="nav-link" href="/tasks/create">Create Task</a>
        </li>

    <% } else if (user && user.role === 'member') { %>
        <li class="nav-item">
        <a class="nav-link" href="/tasks">My Tasks</a>
        </li>

    <% } %>

    </ul>

      <a href="/auth/logout" class="btn btn-danger btn-sm">Logout</a>
    </div>
  </div>
</nav>

<div class="container mt-4">
  <%- body %>
</div>

</body>
</html>
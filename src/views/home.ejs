<!DOCTYPE html>
<html>
<head>
  <title>Task Manager</title>

  <meta name="viewport" content="width=device-width, initial-scale=1">

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css">
</head>

<body class="bg-light">

<!-- 🔥 HERO SECTION -->
<div class="container py-5">

  <div class="row align-items-center">

    <!-- LEFT CONTENT -->
    <div class="col-md-6">

      <h1 class="display-5 fw-bold mb-3">
        Task Management System
      </h1>

      <p class="lead text-muted mb-4">
        Organize projects, assign tasks, and track progress with clarity.
        Built for teams that want control without complexity.
      </p>

      <a href="/auth/login" class="btn btn-primary btn-lg px-4">
        Get Started
      </a>

    </div>

    <!-- RIGHT VISUAL -->
    <div class="col-md-6 text-center">

      <div class="card shadow-sm p-4 border-0">

        <h6 class="text-muted mb-3">Quick Overview</h6>

        <div class="d-flex justify-content-between mb-2">
          <span>Total Tasks</span>
          <strong>128</strong>
        </div>

        <div class="d-flex justify-content-between mb-2">
          <span>In Progress</span>
          <strong class="text-warning">42</strong>
        </div>

        <div class="d-flex justify-content-between mb-2">
          <span>Completed</span>
          <strong class="text-success">76</strong>
        </div>

        <div class="d-flex justify-content-between">
          <span>Overdue</span>
          <strong class="text-danger">10</strong>
        </div>

      </div>

    </div>

  </div>

</div>


<!-- 🔥 FEATURES SECTION -->
<div class="container pb-5">

  <div class="row text-center">

    <div class="col-md-4">
      <div class="card p-4 shadow-sm border-0 h-100">
        <h5>Project Management</h5>
        <p class="text-muted">
          Create and manage multiple projects with ease.
        </p>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card p-4 shadow-sm border-0 h-100">
        <h5>Task Assignment</h5>
        <p class="text-muted">
          Assign tasks to team members and track progress.
        </p>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card p-4 shadow-sm border-0 h-100">
        <h5>Analytics Dashboard</h5>
        <p class="text-muted">
          Get insights into productivity and workload.
        </p>
      </div>
    </div>

  </div>

</div>


<!-- 🔥 FOOTER -->
<div class="text-center text-muted py-3 small">
  © TaskManager
</div>

</body>
</html>
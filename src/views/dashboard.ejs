<h3 class="mb-4">Dashboard</h3>

<% if (user && user.role === 'admin') { %>

  <!-- STATS -->
  <div class="row mb-4">
    <div class="col-md-3">
      <div class="card p-3 text-center">
        <h6>Total</h6>
        <h3><%= stats.total %></h3>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card p-3 text-center text-success">
        <h6>Completed</h6>
        <h3><%= stats.completed %></h3>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card p-3 text-center text-warning">
        <h6>Pending</h6>
        <h3><%= stats.pending %></h3>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card p-3 text-center text-danger">
        <h6>Overdue</h6>
        <h3><%= stats.overdue %></h3>
      </div>
    </div>
  </div>

  <!-- CHARTS GRID -->
  <div class="row">

    <!-- PROJECT CHART -->
    <div class="col-md-6">
      <div class="card p-3 shadow-sm">
        <h6 class="mb-2">Tasks per Project</h6>
        <canvas id="projectChart" style="max-height:300px;"></canvas>
      </div>
    </div>

    <!-- STATUS CHART -->
    <div class="col-md-6">
      <div class="card p-3 shadow-sm">
        <h6 class="mb-2">Status Breakdown</h6>
        <canvas id="statusChart" style="max-height:300px;"></canvas>
      </div>
    </div>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <script>
    // PROJECT DATA
    const rawData = <%- JSON.stringify(stats.tasksPerProject || []) %>;

    const labels = rawData.map(t => t.Project ? t.Project.name : 'Unknown');
    const data = rawData.map(t => t.count || (t.dataValues ? t.dataValues.count : 0));

    if (labels.length > 0) {
      new Chart(document.getElementById('projectChart'), {
        type: 'bar',
        data: {
          labels: labels,
          datasets: [{
            label: 'Tasks',
            data: data,
            backgroundColor: '#0d6efd'  // Bootstrap primary blue
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          scales: {
            y: { beginAtZero: true }
          }
        }
      });
    }

    // STATUS DATA
    const statusData = <%- JSON.stringify(stats.statusBreakdown || []) %>;

    const statusLabels = statusData.map(s => s.status);
    const statusCounts = statusData.map(s => s.count || (s.dataValues ? s.dataValues.count : 0));

    if (statusLabels.length > 0) {
      new Chart(document.getElementById('statusChart'), {
        type: 'pie',
        data: {
          labels: statusLabels,
          datasets: [{
            data: statusCounts,
            backgroundColor: [
              '#6c757d', // todo - gray
              '#ffc107', // in_progress - yellow
              '#198754'  // done - green
            ]
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false
        }
      });
    }
  </script>

<% } else if (user && user.role === 'member') { %>

  <!-- MEMBER DASHBOARD -->
  <div class="row mb-4">
    <div class="col-md-4">
      <div class="card p-3 text-center text-success">
        Completed: <%= completed %>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card p-3 text-center text-warning">
        Pending: <%= pending %>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card p-3 text-center text-danger">
        Overdue: <%= overdue %>
      </div>
    </div>
  </div>

  <% if (tasks.length === 0) { %>
    <div class="alert alert-info">No tasks assigned</div>
  <% } %>

  <% tasks.forEach(t => { %>
    <div class="card mb-2 p-2">
      <strong><%= t.title %></strong> - <%= t.status %>
    </div>
  <% }) %>

<% } %>
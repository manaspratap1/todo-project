<div class="container py-4">

  <!-- 🔥 HEADER -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-semibold mb-0">Tasks</h3>

    <% if (user && user.role === 'admin') { %>
      <a href="/tasks/create" class="btn btn-primary">
        + Create Task
      </a>
    <% } %>
  </div>

  <% if (tasks.length === 0) { %>
    <div class="alert alert-info">No tasks assigned</div>
  <% } %>

  <div class="row g-4">

    <% tasks.forEach(t => { %>

    <div class="col-md-6">
      <div class="card shadow-sm border-0 p-3 h-100">

        <!-- 🔥 TOP SECTION -->
        <div class="d-flex justify-content-between align-items-start mb-2">

          <div>
            <h5 class="mb-1 fw-semibold"><%= t.title %></h5>

            <% if (t.Project) { %>
              <small class="text-muted">
                <%= t.Project.name %>
              </small>
            <% } %>
          </div>

          <!-- STATUS BADGE -->
          <% if (t.status === 'done') { %>
            <span class="badge bg-success">Done</span>
          <% } else if (t.status === 'in_progress') { %>
            <span class="badge bg-warning text-dark">In Progress</span>
          <% } else { %>
            <span class="badge bg-secondary">Todo</span>
          <% } %>

        </div>

        <!-- DESCRIPTION -->
        <% if (t.description) { %>
          <p class="text-muted small mb-3">
            <%= t.description %>
          </p>
        <% } %>

        <!-- 🔥 META STRIP -->
        <div class="d-flex flex-wrap gap-2 mb-3">

          <% if (t.due_date) { %>
            <span class="badge bg-light text-dark border">
              📅 <%= new Date(t.due_date).toLocaleDateString() %>
            </span>
          <% } %>

          <!-- PRIORITY BADGE (FIXED) -->
          <% if (t.priority === 'high') { %>
            <span class="badge bg-danger">High</span>
          <% } else if (t.priority === 'medium') { %>
            <span class="badge bg-warning text-dark">Medium</span>
          <% } else { %>
            <span class="badge bg-secondary">Low</span>
          <% } %>

          <% if (user && user.role === 'admin' && t.assignee) { %>
            <span class="badge bg-light text-dark border">
              👤 <%= t.assignee.name %>
            </span>
          <% } %>

        </div>

        <hr class="my-2">

        <!-- 🔥 ACTIONS -->
        <div class="d-flex justify-content-between align-items-center mt-auto">

          <!-- STATUS BUTTONS -->
          <form method="POST" action="/tasks/update-status/<%= t.id %>">
            <div class="btn-group btn-group-sm">

              <button name="status" value="todo"
                class="btn <%= t.status === 'todo' ? 'btn-secondary' : 'btn-outline-secondary' %>">
                Todo
              </button>

              <button name="status" value="in_progress"
                class="btn <%= t.status === 'in_progress' ? 'btn-warning' : 'btn-outline-warning' %>">
                Progress
              </button>

              <button name="status" value="done"
                class="btn <%= t.status === 'done' ? 'btn-success' : 'btn-outline-success' %>">
                Done
              </button>

            </div>
          </form>

          <% if (user && user.role === 'admin') { %>

            <div class="d-flex gap-2">

              <a href="/tasks/edit/<%= t.id %>" class="btn btn-sm btn-outline-warning">
                Edit
              </a>

              <form method="POST" action="/tasks/delete/<%= t.id %>">
                <button class="btn btn-sm btn-outline-danger">
                  Delete
                </button>
              </form>

            </div>

          <% } %>

        </div>

      </div>
    </div>

    <% }) %>

  </div>

</div>
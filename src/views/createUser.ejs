<div class="container py-4">

  <!-- 🔥 HEADER -->
  <div class="mb-4">
    <h3 class="fw-semibold mb-1">Create User</h3>
    <p class="text-muted small mb-0">
      Add a new team member and assign their role
    </p>
  </div>

  <!-- 🔥 FORM CARD -->
  <div class="card shadow-sm border-0 p-4" style="max-width:500px;">

    <!-- ERROR -->
    <% if (typeof error !== 'undefined') { %>
      <div class="alert alert-danger">
        <%= error %>
      </div>
    <% } %>

    <form method="POST" action="/users/create">

      <!-- NAME -->
      <div class="mb-3">
        <label class="form-label small fw-semibold">Full Name</label>
        <input 
          name="name" 
          class="form-control form-control-lg" 
          placeholder="e.g. John Doe"
          required 
        />
      </div>

      <!-- EMAIL -->
      <div class="mb-3">
        <label class="form-label small fw-semibold">Email</label>
        <input 
          name="email" 
          type="email"
          class="form-control" 
          placeholder="e.g. john@example.com"
          required 
        />
      </div>

      <!-- PASSWORD -->
      <div class="mb-3">
        <label class="form-label small fw-semibold">Password</label>
        <input 
          type="password" 
          name="password" 
          class="form-control" 
          placeholder="Enter password"
          required 
        />
      </div>

      <!-- ROLE -->
      <div class="mb-4">
        <label class="form-label small fw-semibold">Role</label>
        <select name="role" class="form-select">
          <option value="member" selected>Member</option>
          <option value="admin">Admin</option>
        </select>

        <small class="text-muted">
          Admins can manage projects and tasks. Members can only update assigned tasks.
        </small>
      </div>

      <!-- ACTIONS -->
      <div class="d-flex justify-content-between">

        <a href="/users" class="btn btn-outline-secondary">
          Cancel
        </a>

        <button class="btn btn-success px-4">
          Create User
        </button>

      </div>

    </form>

  </div>

</div>
<h3 class="mb-3">Projects</h3>

<a href="/projects/create" class="btn btn-primary mb-3">Create Project</a>

<div class="row">
  <% projects.forEach(p => { %>
    <div class="col-md-4">
      <div class="card p-3 mb-3 shadow-sm">
        <h5><%= p.name %></h5>
        <p><%= p.description %></p>
      </div>
    </div>
  <% }) %>
</div>